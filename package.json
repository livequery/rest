{
    "name": "@livequery/rest",
    "repository": {
        "url": "https://github.com/livequery/rest"
    },
    "version": "2.0.67",
    "type": "module",
    "description": "",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/**/*"
    ],
    "dependencies": {
        "rxjs": "^7.8.1",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@livequery/new": "2.0.61",
        "typescript": "5.6.3"
    },
    "peerDependencies": {},
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap",
    "build:types": "bunx tsc -p tsconfig.build.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:watch": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --watch",
    "prepublishOnly": "bun run build"
  },
    "author": "",
    "license": "ISC"
}